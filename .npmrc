# =============================================================================
# .npmrc — PetLife | Configuração de Segurança (pnpm ≥ 10.16)
# =============================================================================
# Gerenciador de pacotes: pnpm
# Objetivo: apenas pacotes oficiais, sem execução de scripts arbitrários,
# sem instalação automática de dependências secundárias,
# e apenas pacotes publicados há mais de 10 dias.
# =============================================================================

# ─── REGISTRO OFICIAL ────────────────────────────────────────────────────────
# Força o uso exclusivo do registry oficial do npm.
# O pnpm rejeita qualquer outro registry não declarado explicitamente.
registry=https://registry.npmjs.org/

# ─── IDADE MÍNIMA DE PACOTES (Supply Chain Defense) ──────────────────────────
# Bloqueia a instalação de qualquer pacote (ou nova versão de pacote) publicado
# há menos de 10 dias. Valor em MINUTOS.
#
#   10 dias × 24h × 60min = 14400 minutos
#
# Requer pnpm v10.16+. A partir do pnpm v11, o padrão é 1440 min (1 dia).
# Protege contra: typosquatting, account hijacking, pacotes maliciosos
# recém-publicados antes de serem detectados pelo npm audit.
#
# Para instalar um pacote mais novo em caráter excepcional (patch urgente),
# use minimumReleaseAgeExclude no pnpm-workspace.yaml.
minimum-release-age=14400

# ─── BLOQUEIO DE SCRIPTS DE CICLO DE VIDA ────────────────────────────────────
# CRÍTICO: impede a execução de qualquer script durante a instalação:
#   preinstall, install, postinstall, prepare, prepublish, prepack, postpack
# Principal defesa contra supply chain attacks via código malicioso em postinstall.
ignore-scripts=true

# ─── PEER DEPENDENCIES — SEM INSTALAÇÃO AUTOMÁTICA ──────────────────────────
# Impede que o pnpm instale peer dependencies automaticamente sem declaração
# explícita no package.json. Elimina a instalação silenciosa de pacotes secundários.
auto-install-peers=false

# Falha o install se houver peer dependencies incompatíveis não resolvidas.
strict-peer-dependencies=true

# ─── FONTES EXÓTICAS BLOQUEADAS ──────────────────────────────────────────────
# Impede que dependências indiretas usem fontes não-registry
# (git URLs, tar remotos, file:, etc.). Garante que tudo vem do registry oficial.
block-exotic-subdeps=true

# ─── ISOLAMENTO DE NODE_MODULES (padrão pnpm) ────────────────────────────────
# O pnpm NÃO faz hoist por padrão — node_modules é estritamente isolado.
# Cada pacote só acessa as suas dependências declaradas (sem acesso fantasma).
shamefully-hoist=false
hoist=false

# ─── LOCKFILE OBRIGATÓRIO ────────────────────────────────────────────────────
# Garante que pnpm-lock.yaml seja sempre gerado e respeitado.
# No CI, use `pnpm install --frozen-lockfile` para rejeitar qualquer diferença.
lockfile=true

# Impede alteração do lockfile durante `pnpm install` em desenvolvimento.
prefer-frozen-lockfile=true

# ─── VERSÕES EXATAS ──────────────────────────────────────────────────────────
# Salva versões exatas (sem ^ ou ~) ao adicionar novos pacotes com `pnpm add`.
# Evita que atualizações automáticas introduzam código não revisado.
save-exact=true

# ─── STORE COMPARTILHADO ─────────────────────────────────────────────────────
# Diretório central do pnpm store (hard links — economiza espaço em disco).
# Todos os pacotes são verificados por integridade via SHA512 antes de usar.
store-dir=~/.pnpm-store

# Verifica a integridade dos arquivos do store antes de cada install.
verify-store-integrity=true

# ─── WORKSPACE ───────────────────────────────────────────────────────────────
# Resolve pacotes do workspace antes de buscar no registry.
prefer-workspace-packages=true

# Resolve peer dependencies a partir do workspace root.
resolve-peers-from-workspace-root=true

# ─── SEGURANÇA ADICIONAL ─────────────────────────────────────────────────────
# Desabilita notificações de update (sem chamadas de rede desnecessárias).
update-notifier=false

# Desabilita mensagens de funding.
fund=false
