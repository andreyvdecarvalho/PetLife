{
  "name": "petlife",
  "version": "1.0.0",
  "private": true,
  "description": "Toda a vida do seu pet em um só lugar",
  "packageManager": "pnpm@10.34.4",
  "engines": {
    "node": "22.0.0",
    "pnpm": "10.34.4"
  },
  "scripts": {
    "dev:web": "pnpm --filter web run dev",
    "dev:mobile": "pnpm --filter mobile run start",
    "build:web": "pnpm --filter web run build",
    "test:web": "pnpm --filter web run test",
    "test:web:coverage": "pnpm --filter web run test:coverage",
    "lint": "pnpm --filter '*' run lint",
    "typecheck": "pnpm --filter '*' run typecheck"
  }
}
